# ============================================
# VendiMax - Configuración de Entorno
# ============================================

# ============================================
# BASE DE DATOS
# ============================================
DATABASE_URL="postgresql://user:password@localhost:5432/vendimax"

# ============================================
# AUTENTICACIÓN (NextAuth v5)
# ============================================
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="genera-un-secreto-con-openssl-rand-base64-32"
AUTH_SECRET="el-mismo-secreto-que-nextauth"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
ADMIN_SSO_EMAILS="ceo@empresa.com,cto@empresa.com"
ADMIN_GOOGLE_WORKSPACE_DOMAIN="empresa.com"
NEXT_PUBLIC_ADMIN_EMAIL="ceo@empresa.com"
NEXT_PUBLIC_ADMIN_SSO_ENABLED="false"
NEXT_PUBLIC_ADMIN_SSO_DOMAIN="empresa.com"
NEXT_PUBLIC_MAGIC_LINK_ENABLED="true"

# ============================================
# MERCADOPAGO (Suscripciones en ARS)
# ============================================
MERCADOPAGO_ACCESS_TOKEN="APP_USR-..."
MERCADOPAGO_PUBLIC_KEY="APP_USR-..."
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================
# AFIP (Facturación Electrónica - Opcional)
# ============================================
AFIP_CUIT=""
AFIP_CERT_PATH=""
AFIP_KEY_PATH=""
AFIP_PRODUCTION=false

# ============================================
# DEMO
# ============================================
DEMO_RESET_KEY="clave-secreta-para-resetear-demo"

# ============================================
# CRON JOBS
# ============================================
CRON_SECRET="genera-un-secreto-para-cron-jobs"

# ============================================
# EMAIL (Para notificaciones - Opcional)
# ============================================
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="tu-email@gmail.com"
SMTP_PASSWORD="tu-contraseña-de-aplicacion"
SMTP_FROM="no-reply@tudominio.com"

# ============================================
# ALMACENAMIENTO (Imágenes - Opcional)
# ============================================
# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# O AWS S3
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="us-east-1"
AWS_S3_BUCKET=""

# ============================================
# ANALYTICS Y MONITOREO
# ============================================
NEXT_PUBLIC_GA_ID=""
SENTRY_DSN=""

# ============================================
# RATE LIMITING (Opcional - usar Upstash Redis en producción)
# ============================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ============================================
# CONFIGURACIÓN DEL SITIO
# ============================================
NEXT_PUBLIC_SITE_NAME="VendiMax"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_DESCRIPTION="Sistema POS completo para tu negocio"

# ============================================
# MODO
# ============================================
NODE_ENV="development"

